# Copy to .env and fill locally. Never commit .env.

# Runtime endpoints. Keep inference servers bound to loopback and reach them
# through SSH tunnels; do not expose their ports publicly.
RTDM_SERVER=tcp://127.0.0.1:5557
SAM3_SERVER=tcp://127.0.0.1:5558
RTDM_FPS=10
SAM3_FPS=1

# SSH tunnel. Use an SSH host alias from ~/.ssh/config when possible.
SEGMENTATION_SSH_TARGET=
SEGMENTATION_SSH_PORT=22
SEGMENTATION_SSH_IDENTITY=

# Robot LAN settings. These values deliberately contain no lab address.
ROBOT_IP=
ROBOT_PORT=8088
ROBOT_CAMERA_NAME=Camera-000
ROBOT_API_PATH=third_party/seer_camera

# Capture and measurement
WIDTH=1280
HEIGHT=720
CAMERA_FPS=15
MAX_CENTER_Z_MM=1500
MIN_DIMENSION_MM=10
MAX_DIMENSION_MM=450
MEASUREMENT_CONFIG=configs/measurement_default.json
SAVE_ROOT=data

# Training paths. Datasets and weights stay outside Git.
TRAIN_DATASET_DIR=data/training/sam3_teacher_coco
TRAIN_OUTPUT_DIR=runs/maskrcnn_sam3_teacher
TRAIN_DEVICE=cuda
TRAIN_EPOCHS=12
TRAIN_BATCH_SIZE=2
TRAIN_WORKERS=4
